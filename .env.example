# Google AI Studio (Gemini) — free API key: https://aistudio.google.com/apikey
# Use GEMINI_API_KEY (recommended): kept server-side; Vite proxy attaches it — not exposed in the JS bundle.
GEMINI_API_KEY=

# Optional: model id (default: gemini-2.5-flash). Examples: gemini-2.5-flash, gemini-3-flash-preview
# GEMINI_MODEL=gemini-2.5-flash

# Optional override for the browser-built request (usually unnecessary):
# VITE_GEMINI_MODEL=gemini-2.5-flash
